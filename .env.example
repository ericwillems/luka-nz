# PagesCMS Environment Configuration

# GitHub configuration for PagesCMS
# Update these with your actual credentials from GitHub OAuth app
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# GitHub repository information
GITHUB_REPO_OWNER=your_username
GITHUB_REPO_NAME=luka-nz

# Optional: PagesCMS specific settings
PAGES_CMS_BRANCH=main
