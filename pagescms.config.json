{
  "title": "Portfolio Site",
  "backend": {
    "name": "github",
    "repo": "your-username/luka-nz"
  },
  "media_folder": "static/uploads",
  "public_folder": "/uploads",
  "collections": [
    {
      "name": "projects",
      "label": "Projects",
      "folder": "content/projects",
      "create": true,
      "slug": "{{slug}}",
      "fields": [
        {
          "name": "title",
          "label": "Title",
          "widget": "string",
          "required": true
        },
        {
          "name": "description",
          "label": "Description",
          "widget": "text"
        },
        {
          "name": "image",
          "label": "Project Image",
          "widget": "image",
          "required": false
        },
        {
          "name": "link",
          "label": "Project Link",
          "widget": "string",
          "required": false
        },
        {
          "name": "technologies",
          "label": "Technologies",
          "widget": "list",
          "field": {
            "label": "Technology",
            "name": "technology",
            "widget": "string"
          }
        },
        {
          "name": "draft",
          "label": "Draft",
          "widget": "boolean",
          "default": false
        },
        {
          "name": "body",
          "label": "Content",
          "widget": "markdown"
        }
      ]
    },
    {
      "name": "posts",
      "label": "Posts",
      "folder": "content/posts",
      "create": true,
      "slug": "{{slug}}",
      "fields": [
        {
          "name": "title",
          "label": "Title",
          "widget": "string",
          "required": true
        },
        {
          "name": "date",
          "label": "Publish Date",
          "widget": "datetime",
          "format": "2006-01-02T15:04:05Z07:00"
        },
        {
          "name": "categories",
          "label": "Categories",
          "widget": "list",
          "field": {
            "label": "Category",
            "name": "category",
            "widget": "string"
          }
        },
        {
          "name": "tags",
          "label": "Tags",
          "widget": "list",
          "field": {
            "label": "Tag",
            "name": "tag",
            "widget": "string"
          }
        },
        {
          "name": "draft",
          "label": "Draft",
          "widget": "boolean",
          "default": false
        },
        {
          "name": "body",
          "label": "Content",
          "widget": "markdown"
        }
      ]
    },
    {
      "name": "pages",
      "label": "Pages",
      "folder": "content/pages",
      "create": false,
      "delete": false,
      "fields": [
        {
          "name": "title",
          "label": "Title",
          "widget": "string",
          "required": true
        },
        {
          "name": "draft",
          "label": "Draft",
          "widget": "boolean",
          "default": false
        },
        {
          "name": "body",
          "label": "Content",
          "widget": "markdown"
        }
      ]
    },
    {
      "name": "about",
      "label": "About",
      "folder": "content/about",
      "create": false,
      "delete": false,
      "fields": [
        {
          "name": "title",
          "label": "Title",
          "widget": "string",
          "required": true
        },
        {
          "name": "draft",
          "label": "Draft",
          "widget": "boolean",
          "default": false
        },
        {
          "name": "body",
          "label": "Content",
          "widget": "markdown"
        }
      ]
    }
  ]
}
